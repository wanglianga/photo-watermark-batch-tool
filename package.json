{
  "name": "photo-watermark-batch-tool",
  "version": "1.0.0",
  "description": "本地照片版权水印批处理工具 - 面向摄影师、修图师和图库运营",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "photo",
    "watermark",
    "batch",
    "exif",
    "photography"
  ],
  "author": "Photo Watermark Tool",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "sharp": "^0.33.1",
    "exifr": "^7.1.3",
    "piexifjs": "^1.0.6"
  },
  "build": {
    "appId": "com.photowatermark.tool",
    "productName": "照片水印批处理工具",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
